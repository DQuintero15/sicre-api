{
  "ConnectionStrings": {
    "DefaultConnection": "Database_Connection_String"
  },
  "Seed": {
    "Email": "seed@example.com",
    "DefaultUserPassword": ""
  },
  "FrontendUrl": "https://domain.com",
  "BackendUrl": "https://api.domain.com",
  "Smtp": {
    "DisplayName": "SICRE",
    "Username": "SMTP_Username",
    "Host": "SMTP_Host",
    "Password": "SMTP_Password",
    "RedirectTo": "",
    "Port": 587,
    "EnableSsl": true
  },
  "Jwt": {
    "SecretKey": "Change_This_To_A_Secure_Random_Secret_Key_Min32Chars",
    "TemporaryTokenExpirationMinutes": 30,
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7,
    "Issuer": "Sicre.Api",
    "Audience": "Sicre.Client"
  },
  "Cors": {
    "AllowedOrigins": ["https://domain.com"],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["*"],
    "AllowCredentials": true
  },
  "GoogleDrive": {
    "ClientId": "Google_OAuth_ClientId",
    "ClientSecret": "Google_OAuth_ClientSecret",
    "RedirectUri": "https://api.domain.com/api/google-drive-auth/callback",
    "ApplicationName": "SICRE",
    "FolderId": "Google_Drive_FolderId"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "DataProtection": {
    "KeysPath": "/root/.aspnet/DataProtection-Keys"
  },
  "AllowedHosts": "*"
}
